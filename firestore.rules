rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Game Status Document
    // Anyone can read the game status
    // Only authenticated users (admins) can write/update the game status
    match /game/status {
      allow read, write: if true;
    }

    // Teams Collection
    // Note: This allows public writes. Update this once authentication is set up.
    match /teams/{teamId} {
      allow read, write: if true;
    }

    // Default catch-all rule: Deny access to everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
